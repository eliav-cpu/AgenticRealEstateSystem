# Agentic Real Estate System - Environment Configuration

# =============================================================================
# DATA LAYER CONFIGURATION
# =============================================================================

# Data Mode: mock (development/testing) or real (production)
DATA_MODE=mock

# Mock data path (used in mock mode)
DATA_MOCK_DATA_PATH=app/data/fixtures

# =============================================================================
# EXTERNAL API CONFIGURATION (Required for DATA_MODE=real)
# =============================================================================

# RentCast API - Real property data
RENTCAST_API_KEY=your_rentcast_api_key_here
RENTCAST_BASE_URL=https://api.rentcast.io/v1

# Google Calendar API - Real appointment scheduling
GOOGLE_CALENDAR_CREDENTIALS=/path/to/google/credentials.json
GOOGLE_CALENDAR_ID=primary

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Groq Configuration
GROQ_API_KEY=your_groq_api_key
LLM_PROVIDER=groq
LLM_DEFAULT_MODEL=mistralai/mistral-7b-instruct:free
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Agent-specific models
LLM_SEARCH_MODEL=mistralai/mistral-7b-instruct:free
LLM_PROPERTY_MODEL=mistralai/mistral-7b-instruct:free
LLM_SCHEDULING_MODEL=mistralai/mistral-7b-instruct:free

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (Main database)
DB_URL=postgresql://user:password@localhost:5432/real_estate
DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# DuckDB (Mock data)
DUCKDB_DB_PATH=data/properties.duckdb
DUCKDB_AUTO_MIGRATE=true
DUCKDB_FORCE_RELOAD=false

# Redis (Caching)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=10

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

APP_NAME=Agentic Real Estate
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

SECRET_KEY=dev-secret-key-change-in-production
TOKEN_EXPIRE_MINUTES=30
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================

# Logging
OBS_LOG_LEVEL=INFO
OBS_LOG_FORMAT=json

# Metrics
OBS_METRICS_ENABLED=true
OBS_METRICS_PORT=8090

# Tracing
OBS_TRACING_ENABLED=true
OBS_JAEGER_ENDPOINT=

# Logfire
LOGFIRE_TOKEN=

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-real-estate
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# RESILIENCE CONFIGURATION
# =============================================================================

# Circuit Breaker
RESILIENCE_CIRCUIT_ENABLED=true
RESILIENCE_FAILURE_THRESHOLD=5
RESILIENCE_RECOVERY_TIMEOUT=60

# Retry
RESILIENCE_MAX_RETRIES=3
RESILIENCE_RETRY_DELAY=1.0
RESILIENCE_RETRY_BACKOFF=2.0

# Timeout
RESILIENCE_DEFAULT_TIMEOUT=30.0

# =============================================================================
# SWARM CONFIGURATION
# =============================================================================

# Handoff
SWARM_HANDOFF_TIMEOUT=5.0
SWARM_MAX_HANDOFFS=10

# Context
SWARM_CONTEXT_WINDOW=4000
SWARM_CONTEXT_OVERLAP=200

# =============================================================================
# API RATE LIMITING
# =============================================================================

MAX_REQUESTS_PER_MINUTE=60
REQUEST_TIMEOUT=30

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# For local development:
# 1. Copy this file to .env
# 2. Keep DATA_MODE=mock (no external API keys needed)
# 3. Update LLM keys if testing AI features

# For production:
# 1. Set DATA_MODE=real
# 2. Configure all *_API_KEY values
# 3. Set ENVIRONMENT=production
# 4. Use strong SECRET_KEY
# 5. Disable DEBUG=false
